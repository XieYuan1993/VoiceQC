# Normalize line endings to LF in the repo; Windows checkouts get CRLF.
* text=auto eol=lf
*.sh text eol=lf
*.command text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.sql text eol=lf

# Binaries — never munge.
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.woff2 binary
*.woff binary
