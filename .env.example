# Top-level shared env vars used by docker-compose, alembic, seed, and the apps.
# Per-app env vars live in apps/<name>/.env.example.
#
# Copy this file to `.env` (`make bootstrap` does it and generates secrets).

ENV=development

# Postgres. Host ports are shifted (55433/56380/1026/8026) so this stack
# coexists with Voicebot-Platform's compose on the same machine.
POSTGRES_USER=voiceqa
POSTGRES_PASSWORD=voiceqa
POSTGRES_DB=voiceqa
POSTGRES_HOST=localhost
POSTGRES_PORT=55433

# Async DSN used by SQLAlchemy (api/worker/seed). Alembic rewrites it to
# psycopg form in env.py automatically.
DATABASE_URL=postgresql+asyncpg://voiceqa:voiceqa@localhost:55433/voiceqa
# Sync DSN for the Auth.js pg adapter (apps/web/.env.local).
DATABASE_URL_SYNC=postgresql://voiceqa:voiceqa@localhost:55433/voiceqa

# Redis (Celery broker + result backend)
REDIS_URL=redis://localhost:56380/0
REDIS_PORT=56380

# SMTP (MailHog locally; replace with the real relay in prod).
# Used by apps/api for password-reset emails.
SMTP_HOST=localhost
SMTP_PORT=1026
SMTP_USER=
SMTP_PASS=
MAIL_FROM=VoiceQA <noreply@voiceqa.local>
MAILHOG_UI_PORT=8026

# Auth.js — MUST be the same value across apps/web and apps/api (the api
# decrypts the Auth.js session cookie). Generate: `openssl rand -base64 32`.
NEXTAUTH_SECRET=replace-me-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3020

# Shared secret between apps/web (Auth.js authorize()) and apps/api's
# /api/auth/verify-credentials. Generate: `openssl rand -base64 32`.
INTERNAL_API_SECRET=replace-me-internal-secret

# AES-256-GCM key for secrets stored in the DB (Phase 4: SSO client secret,
# txn API credentials). Generate: `openssl rand -base64 32`.
APP_ENCRYPTION_KEY=replace-me-with-openssl-rand-base64-32

LOG_LEVEL=INFO

# Seed (dev only — change the password immediately on real deployments)
SEED_ADMIN_EMAIL=admin@local.test
SEED_ADMIN_PASSWORD=voiceqa-admin-1

# --- Google Cloud (Phase 1+) -------------------------------------------------
# Vertex Gemini + Speech-to-Text v2 + GCS audio storage all authenticate via
# ADC. Either set a service-account key path, or use
# `gcloud auth application-default login`.
# GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=
# STT runs in asia-southeast1 (chirp_2 has no HK region); GCS bucket lives
# in asia-east2 (Hong Kong) for data-at-rest residency. See DESIGN.md §1.
GOOGLE_STT_LOCATION=asia-southeast1
VERTEX_LLM_LOCATION=asia-southeast1
GCS_BUCKET_AUDIO=quam-voiceqa-dev
GOOGLE_STT_MODEL=chirp_2
VERTEX_LLM_MODEL=gemini-3.5-flash
LLM_PROVIDER=dashscope
LLM_FALLBACK_PROVIDER=
DASHSCOPE_LLM_MODEL=qwen3.7-max

# Qwen3-ASR (Alibaba Cloud Model Studio / DashScope) — the default ASR provider
# (asr.provider="qwen"). Required only when using the qwen provider. Get a key
# from Model Studio; the host is shown next to it.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://<your-workspace-host>.ap-southeast-1.maas.aliyuncs.com

# Tencent Cloud ASR. Required only when using asr.provider="tencent".
# Tencent's "普方英大模型" is selected with asr.model="16k_zh_en".
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_ASR_REGION=ap-guangzhou
ASR_AUDIO_PROXY_BASE_URL=
RECORDING_CONVERT_TIMEOUT_SECONDS=1800
RECORDING_STT_TIMEOUT_SECONDS=1800
RECORDING_EVAL_TIMEOUT_SECONDS=3600
RECORDING_QUEUE_REDISPATCH_SECONDS=86400
RECORDING_RESUME_STALE_SECONDS=300
RECORDING_RESUME_MAX_ATTEMPTS=1
STT_MAX_IN_FLIGHT=3
WORKER_MAX_TASKS_PER_CHILD=
WORKER_MAX_MEMORY_PER_CHILD=
