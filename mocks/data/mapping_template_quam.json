{
  "name": "Quam Client History Order Report",
  "kind": "csv",
  "config": {
    "encoding": "utf-8-sig",
    "header_row": 1,
    "sheet_name": "Sheet1",
    "timezone": "Asia/Hong_Kong",
    "date_format": "%Y-%m-%d %H:%M:%S",
    "suffix_duplicate_ext_id": true,
    "column_mapping": {
      "trade_date": "交易日",
      "ordered_at": "生成時間",
      "executed_at": "生成時間",
      "ext_txn_id": "訂單號",
      "client_account": "證券賬號",
      "client_name": "客户姓名",
      "stock_code": "證券代碼",
      "stock_name": "證券名稱",
      "side": "買賣方向",
      "price": "委託價格",
      "quantity": "成交數量",
      "amount": "成交金額",
      "broker_code": "經紀人編號",
      "channel": "委託渠道"
    },
    "side_values": {
      "buy": ["買入", "B", "BUY"],
      "sell": ["賣出", "S", "SELL"]
    },
    "channel_values": {
      "phone": ["WTT", "PHONE"],
      "online": ["INTERNET", "MOBILE", "WEB", "網上", "手機"]
    },
    "status_filter": {
      "column": "執行類型",
      "include": ["TradeExec"]
    }
  }
}
