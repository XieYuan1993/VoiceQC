# apps/web env. Copy to apps/web/.env.local for Next.js to pick it up.
# Most values are inherited from the top-level .env.

DATABASE_URL=postgresql://voiceqa:voiceqa@localhost:55433/voiceqa

NEXTAUTH_URL=http://localhost:3020
# MUST be the same value as the API's NEXTAUTH_SECRET. Generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-openssl-rand-base64-32

# Shared secret for server-to-server calls (authorize() -> verify-credentials).
# MUST match the API's INTERNAL_API_SECRET.
INTERNAL_API_SECRET=replace-me-internal-secret

# AES-256-GCM key for the SSO client secret (Phase 4). MUST match the API's
# APP_ENCRYPTION_KEY — the lazy NextAuth init decrypts the secret read from
# the sso_config row. Generate with: openssl rand -base64 32
APP_ENCRYPTION_KEY=replace-me-with-openssl-rand-base64-32

# Backend API base URL (browser fetches this).
NEXT_PUBLIC_API_URL=http://localhost:7870

# SMTP — intentionally absent. Phase 4 password-reset emails are sent by the
# API, not the web app.
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=VoiceQA <noreply@voiceqa.local>
